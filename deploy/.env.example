# Copy this to `.env` (which is gitignored) and fill it in.
# NEVER commit the real .env — it holds your keys.

# --- The Director's identity -------------------------------------------
# Use the SAME key as your local `.director-key` so the hosted agent keeps
# your house, your folded notes, and your delegated worlds. Two options:
#   • paste the 64-hex string from:  cat .director-key
#   • or an nsec1... string
# If you leave this blank the container invents a NEW identity, and your
# nvoy grants (made to the old npub) will not reach it.
NOIR_DIRECTOR_NSEC=

# --- Your Anthropic key ------------------------------------------------
# THIS BOX SPENDS IT. Server-side only; it never reaches players' browsers.
ANTHROPIC_API_KEY=

# --- Relays the table watches for house / world / notes grants ---------
# Must match the relays your nvoy console publishes to.
NOIR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net

# --- Public guardrails (you are internet-facing now) -------------------
# Only these origins (your game clients) may call the Director. Comma-sep.
# Keep github.io during the transition; drop it once noir.nave.pub is live.
NOIR_ALLOWED_ORIGINS=https://noir.nave.pub,https://jafairweather.github.io
# Max requests per IP per 5 minutes (0 = off).
NOIR_RATE_LIMIT=60
# Hard stop on total Director calls per day — your worst-case spend ceiling.
NOIR_DAILY_CAP=2000

# --- Voice model (optional; defaults to claude-sonnet-5) ---------------
# NOIR_MODEL=claude-sonnet-5

# --- Let's Encrypt contact (real email — you get cert-expiry notices) --
ACME_EMAIL=help@nave.pub

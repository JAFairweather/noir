# The one front door for everything on nave.pub.
# Caddy fetches + renews Let's Encrypt certs automatically, as long as
# each name's DNS A record points at this box and ports 80+443 are open.

{
	email {$ACME_EMAIL}
}

# The hub — the ecosystem front door. Static, served straight off the box
# from ../nave (mounted read-only into this container at /srv/nave).
nave.pub, www.nave.pub {
	root * /srv/nave
	encode gzip zstd
	file_server
}

# The game client — static, served from ../client and the sibling modules
# it imports (lib, gm, shared, eras), mounted read-only at /srv/site.
# `/` lands on the client; the Director itself is a separate subdomain.
noir.nave.pub {
	root * /srv/site
	encode gzip zstd
	# .mjs must be served as JavaScript or the browser refuses the module.
	@mjs path *.mjs
	header @mjs Content-Type "text/javascript; charset=utf-8"
	redir / /client/ 302
	file_server
}

# The Noir Director API — the AI game master. The client above calls this.
director.nave.pub {
	reverse_proxy director:8787
}

# --- Luke — the Claude bot (OpenClaw), exposed the OpenClaw way --------
# READ deploy/DEPLOY.md §8 before enabling. OpenClaw's Control UI is a
# WebSocket app that REQUIRES https at the browser (its device auth uses
# WebCrypto, which won't run over plain http off localhost). Caddy gives
# the browser that https; the internal hop to 57419 stays plain. Caddy
# proxies WebSockets natively — nothing extra needed.
#
# Luke's real lock is OpenClaw's OWN gateway auth (token/password, on by
# default), pinned to this origin via gateway.controlUi.allowedOrigins =
# https://luke.nave.pub. Do NOT wrap it in Caddy basic_auth — that fights
# the WebSocket device-auth. For an OPTIONAL extra outer wall, an IP
# allowlist is safe (it doesn't break the socket); see the commented
# lines below.
#
# luke.nave.pub {
# 	# optional: only let your own IP reach Luke at all —
# 	# @blocked not remote_ip 203.0.113.10/32   # <- your home/office IP
# 	# respond @blocked "forbidden" 403
# 	reverse_proxy host.docker.internal:57419
# }
#
# relay.nave.pub {
# 	reverse_proxy relay:PORT         # the nostr relay (Phase 5)
# }

# The one front door for everything on nave.pub.
# Caddy fetches + renews Let's Encrypt certs automatically, as long as
# each name's DNS A record points at this box and ports 80+443 are open.

{
	email {$ACME_EMAIL}
}

# The hub — the ecosystem front door. Static, served straight off the box
# from ../nave (mounted read-only into this container at /srv/nave).
# The apex gets its OWN cert block: bundling www in here would make Caddy
# order ONE cert for both names, and if www fails to validate (it has no
# explicit A record — only the wildcard) the whole order fails and the
# apex goes down with it. Keep them independent.
nave.pub {
	root * /srv/nave
	encode gzip zstd
	file_server
}

# www just points at the apex. Its own block, so if its cert ever stalls
# it can't take nave.pub with it.
www.nave.pub {
	redir https://nave.pub{uri} permanent
}

# The game client — static, served from ../client and the sibling modules
# it imports (lib, gm, shared, eras), mounted read-only at /srv/site.
# `/` lands on the client; the Director itself is a separate subdomain.
noir.nave.pub {
	root * /srv/site
	encode gzip zstd
	# .mjs must be served as JavaScript or the browser refuses the module.
	@mjs path *.mjs
	header @mjs Content-Type "text/javascript; charset=utf-8"
	redir / /client/ 302
	file_server
}

# The Noir Director API — the AI game master. The client above calls this.
director.nave.pub {
	reverse_proxy director:8787
}

# --- The apps, each served off the box at its own subdomain -----------
# deploy/sites.sh syncs each app's repo into deploy/sites/<name>, mounted
# read-only at /srv/apps/<name>. We serve each REPO ROOT (not a subdir) so
# the apps' sibling imports (../lib, ../shared, ../vendor) resolve. Caddy
# issues a Let's Encrypt cert per subdomain automatically. Adding the next
# app is one line here + one line in sites.sh.
(app) {
	root * /srv/apps/{args[0]}
	encode gzip zstd
	@mjs path *.mjs
	header @mjs Content-Type "text/javascript; charset=utf-8"
	file_server
}

nvelope.nave.pub  { import app nvelope }
nontact.nave.pub  { import app nontact }
notegate.nave.pub { import app notegate }
ntrigue.nave.pub  { import app ntrigue }
nvoy.nave.pub     { import app nvoy }
nherit.nave.pub   { import app nherit }
nscope.nave.pub   { import app nscope }

# --- Luke — a delegated agent, cockpit behind a nostr-signed gate ------
# READ docs/LUKE.md before enabling. Two planes on one host:
#   /            → Luke's public card + gate endpoints (luke-service)
#   /cockpit*    → the real OpenClaw Control UI (host :57419), but ONLY
#                  after forward_auth to the gate returns 200. The gate
#                  opens for exactly one key: your NIP-98-signed master npub.
# OpenClaw's own gateway auth stays on as the inner lock (defense in depth);
# set its gateway.controlUi.allowedOrigins to include https://luke.nave.pub.
# The `luke` service comes up with the normal `docker compose up -d`.
luke.nave.pub {
	encode gzip zstd

	# The cockpit: OpenClaw, gated by the nostr-signed session.
	@cockpit path /cockpit /cockpit/*
	handle @cockpit {
		forward_auth luke:8790 {
			uri /gate/verify
		}
		reverse_proxy host.docker.internal:57419
	}

	# Everything else: Luke's public card + the /gate/* login flow.
	handle {
		reverse_proxy luke:8790
	}
}

# The one front door for everything on nave.pub.
# Caddy fetches + renews Let's Encrypt certs automatically, as long as
# each name's DNS A record points at this box and ports 80+443 are open.

{
	email {$ACME_EMAIL}
}

# The Noir Director API. The game CLIENT is on Cloudflare Pages at
# noir.nave.pub and calls this endpoint.
director.nave.pub {
	reverse_proxy director:8787
}


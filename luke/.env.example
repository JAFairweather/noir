# Copy to luke/.env (gitignored) and fill in. See docs/LUKE.md.
# NEVER commit the real .env — it holds Luke's key.

# --- Luke's own identity ------------------------------------------------
# Luke's nostr key (nsec1… or 64-hex). His npub is his public identity and
# what your grant points at. Leave blank ONLY for a throwaway test — the
# service will invent an ephemeral key and warn.
LUKE_NSEC=

# --- The master: the ONE key the cockpit gate lets in ------------------
# YOUR npub. This is the hard security boundary — the gate opens only for a
# NIP-98 signature from exactly this key. Set it explicitly.
LUKE_MASTER_NPUB=

# --- What you've delegated (shown on Luke's public card) ---------------
LUKE_MANDATE=To keep the master's work moving between visits.
LUKE_NAME=Luke

# --- Session cookie signing --------------------------------------------
# Optional. If unset, it's derived from LUKE_NSEC (so sessions survive
# restarts). Set a random value to rotate all sessions at once.
# GATE_SECRET=
# Cookie lifetime in seconds (default 12h).
# GATE_SESSION_TTL=43200

# --- Port (internal; Caddy is the public face) -------------------------
LUKE_PORT=8790
